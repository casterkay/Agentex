# Copy this file to .env, then replace placeholders with real values.
# Do not commit .env.

# EVM chain used for the demo contracts.
AGENTEX_RPC_URL=https://base-mainnet.example-rpc.invalid
AGENTEX_CHAIN_ID=8453

# Contract deployment wallet. Use a demo-funded hot wallet only.
AGENTEX_DEPLOYER_PRIVATE_KEY=0xREPLACE_WITH_DEPLOYER_PRIVATE_KEY

# Decoder signer for execution proofs.
AGENTEX_DECODER_ADDRESS=0xREPLACE_WITH_DECODER_PUBLIC_ADDRESS
AGENTEX_DECODER_PRIVATE_KEY=0xREPLACE_WITH_DECODER_PRIVATE_KEY

# Fill these after npm run deploy:demo writes deployments/live-v1.json.
AGENTEX_REGISTRY_ADDRESS=0xREPLACE_AFTER_DEPLOY
AGENTEX_DEMO_VENUE_ADDRESS=0xREPLACE_AFTER_DEPLOY

# One demo seller wallet per OpenClaw agent.
AGENTEX_SELLER_PRIVATE_KEY_ALPHA=0xREPLACE_WITH_ALPHA_PRIVATE_KEY
AGENTEX_SELLER_PRIVATE_KEY_BETA=0xREPLACE_WITH_BETA_PRIVATE_KEY
AGENTEX_SELLER_PRIVATE_KEY_GAMMA=0xREPLACE_WITH_GAMMA_PRIVATE_KEY
AGENTEX_SELLER_PRIVATE_KEY_DELTA=0xREPLACE_WITH_DELTA_PRIVATE_KEY

# Filecoin Pin / Filecoin Pay wallet private key.
PRIVATE_KEY=0xREPLACE_WITH_FILECOIN_PRIVATE_KEY

# Symmetric demo encryption key for experience payloads.
# Generate with: openssl rand -hex 32
AGENTEX_EXPERIENCE_KEY=REPLACE_WITH_64_HEX_CHARS

# Optional Aomi wrapper target.
AGENTEX_SERVICE_URL=http://127.0.0.1:8787
