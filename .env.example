# Copy this file to .env, then replace placeholders with real values.
# Do not commit .env.

# EVM chain used for the demo contracts.
AGENTEX_RPC_URL=https://base-mainnet.example-rpc.invalid
AGENTEX_CHAIN_ID=8453

# Contract deployment wallet. Use a demo-funded hot wallet only.
AGENTEX_DEPLOYER_PRIVATE_KEY=0xREPLACE_WITH_DEPLOYER_PRIVATE_KEY

# Decoder signer for execution proofs.
AGENTEX_DECODER_ADDRESS=0xREPLACE_WITH_DECODER_PUBLIC_ADDRESS
AGENTEX_DECODER_PRIVATE_KEY=0xREPLACE_WITH_DECODER_PRIVATE_KEY

# Optional overrides; live commands read these from AGENTEX_DEPLOYMENT_PATH when unset.
AGENTEX_REGISTRY_ADDRESS=
AGENTEX_DEMO_VENUE_ADDRESS=
AGENTEX_DEPLOYMENT_PATH=deployments/live-v1.json
AGENTEX_LIVE_OUTPUT_DIR=demo/live-output

# One demo seller wallet per Aomi-hosted agent.
AGENTEX_SELLER_PRIVATE_KEY_ALPHA=0xREPLACE_WITH_ALPHA_PRIVATE_KEY
AGENTEX_SELLER_PRIVATE_KEY_BETA=0xREPLACE_WITH_BETA_PRIVATE_KEY
AGENTEX_SELLER_PRIVATE_KEY_GAMMA=0xREPLACE_WITH_GAMMA_PRIVATE_KEY
AGENTEX_SELLER_PRIVATE_KEY_DELTA=0xREPLACE_WITH_DELTA_PRIVATE_KEY

# Filecoin Pin / Filecoin Pay wallet private key.
PRIVATE_KEY=0xREPLACE_WITH_FILECOIN_PRIVATE_KEY

# Symmetric demo encryption key for experience payloads.
# Generate with: openssl rand -hex 32
AGENTEX_EXPERIENCE_KEY=REPLACE_WITH_64_HEX_CHARS

# Aomi live hosting and registration.
AGENTEX_SERVICE_URL=https://agentex.example.com
AGENTEX_AOMI_ALLOW_LOCAL=false
AOMI_BACKEND_URL=https://api.aomi.dev
AOMI_APP=agentex
AOMI_API_KEY=
AGENTEX_AOMI_REGISTRATION_DIR=demo/live-output/aomi
AGENTEX_AGENT_REGISTRY=
AGENTEX_AGENT_ID_ALPHA=
AGENTEX_AGENT_ID_BETA=
AGENTEX_AGENT_ID_GAMMA=
AGENTEX_AGENT_ID_DELTA=
AOMI_SESSION_ID_ALPHA=
AOMI_SESSION_ID_BETA=
AOMI_SESSION_ID_GAMMA=
AOMI_SESSION_ID_DELTA=

# Arkhai settlement.
# local creates deterministic demo escrow/fulfillment/arbitration receipts.
# live requires explicit deployed Arkhai/Alkahest addresses and a funded signer.
AGENTEX_ARKHAI_MODE=local
AGENTEX_ARKHAI_RPC_URL=
AGENTEX_ARKHAI_CHAIN_ID=
AGENTEX_ARKHAI_PRIVATE_KEY=
AGENTEX_ARKHAI_TOKEN_ADDRESS=
AGENTEX_ARKHAI_ARBITER_ADDRESS=
AGENTEX_ARKHAI_ERC20_ESCROW_ADDRESS=
AGENTEX_ARKHAI_ORACLE_ADDRESS=
AGENTEX_ARKHAI_EXPERIENCE_ACCESS_OBLIGATION_ADDRESS=

AGENTEX_AGENT_TRADE_BUDGET_MON=0.01
